# Elasticsearch（未設定時はデモモード: インメモリ）
ELASTIC_CLOUD_ID=
ELASTIC_URL=
ELASTIC_API_KEY=
ELASTIC_INDEX_REFERENCE=reference_fingerprints
ELASTIC_INDEX_HITS=infringement_hits
ELASTIC_INDEX_TAKEDOWNS=takedown_requests

# AI
GEMINI_API_KEY=
DEMO_MODE=true

# YouTube Data API v3
YOUTUBE_API_KEY=
YOUTUBE_OWN_CHANNEL_ID=

# X API v2
X_BEARER_TOKEN=

# 権利者情報（DMCA 自動填入）
RIGHTS_HOLDER_NAME=
RIGHTS_HOLDER_ADDRESS=
RIGHTS_HOLDER_EMAIL=
RIGHTS_HOLDER_PHONE=

# 巡回設定
PATROL_INTERVAL_MIN=15
PATROL_ENABLED=true
MATCH_THRESHOLD=0.78
SECONDARY_MATCH_THRESHOLD=0.70
MONITOR_KEYWORDS=作品名,キャラクター名
YOUTUBE_SCAN_DELAY_SEC=1.0
TIKTOK_SCAN_DELAY_SEC=2.0
X_SCAN_DELAY_SEC=1.5

# 照合 v2
HYBRID_MATCH=true
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMS=768
KNN_CANDIDATES=5

# DMCA リトライ
DMCA_RETRY_ENABLED=true
DMCA_RETRY_INTERVAL_MIN=30
DMCA_MAX_RETRIES=3
DMCA_AUTO_SUBMIT=true
PLATFORM_SESSION_DIR=./data/sessions

# Phase 4: Webhook 通知（Slack/Teams 互換）
WEBHOOK_URL=
WEBHOOK_ENABLED=false

# Phase 4: API キー（未設定時は認証スキップ — デモ互換）
# 設定時はダッシュボード SETTINGS から X-API-Key を入力（localStorage 保存）
API_KEY=
